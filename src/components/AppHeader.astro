---
import Container from './Container.astro'
---

<header>
  <nav class="z-10 w-full fixed top-0 h-max backdrop-blur-md">
    <Container>
      <div
        class="group flex flex-wrap items-center justify-between py-2 gap-6 md:py-4 md:gap-0 relative"
      >
        <div class="relative z-20 w-full flex justify-between lg:w-max md:px-0">
          <a href="/" aria-label="logo" class="flex space-x-2 items-center">
            <img
              src="/images/communities/foss.webp"
              alt="FOSS LOGO"
              width="45"
            />
          </a>

          <!-- Hamburger Button -->
          <div class="relative flex items-center lg:hidden max-h-10">
            <label
              role="button"
              for="toggle_nav"
              aria-label="hamburger"
              class="relative p-6 -mr-6 cursor-pointer"
            >
              <div
                aria-hidden="true"
                class="m-auto h-0.5 w-5 rounded bg-sky-900 transition duration-300 group-has-checked:rotate-45 group-has-checked:translate-y-1.5"
              >
              </div>
              <div
                aria-hidden="true"
                class="m-auto mt-2 h-0.5 w-5 rounded bg-sky-900 transition duration-300 group-has-checked:-rotate-45 group-has-checked:-translate-y-1"
              >
              </div>
            </label>
            <input type="checkbox" id="toggle_nav" class="hidden" />
          </div>
        </div>

        <!-- Mobile Overlay -->
        <div
          aria-hidden="true"
          class="fixed z-10 inset-0 h-screen w-screen bg-white/70 backdrop-blur-2xl origin-bottom scale-y-0 transition duration-500 group-has-checked:origin-top group-has-checked:scale-y-100 group-has-checked:opacity-100 group-has-checked:visible lg:hidden"
          onclick="document.getElementById('toggle_nav').checked = false;"
        >
        </div>

        <!-- Navigation Links (Mobile and Desktop) -->
        <div
          class="flex-col z-20 flex-wrap gap-6 p-8 rounded-3xl border border-gray-100 bg-white shadow-2xl shadow-gray-600/10 justify-end w-full invisible opacity-0 translate-y-1 absolute top-full left-0 transition-all duration-300 scale-95 origin-top group-has-checked:scale-100 group-has-checked:opacity-100 group-has-checked:visible lg:relative lg:scale-100 lg:group-has-checked:translate-y-0 lg:translate-y-0 lg:flex lg:flex-row lg:items-center lg:gap-0 lg:p-0 lg:bg-transparent lg:w-7/12 lg:visible lg:opacity-100 lg:border-none lg:shadow-none"
        >
          <ul
            class="tracking-wide font-medium lg:text-sm flex-col flex lg:flex-row gap-6 lg:gap-0"
          >
            <li>
              <a
                href="/#about"
                class="block md:px-4 transition hover:text-primary"
              >
                <span>About</span>
              </a>
            </li>
            <li>
              <a
                href="/fosslearn"
                class="block md:px-4 transition hover:text-primary"
              >
                <span>Foss Learning</span>
              </a>
            </li>
            <li>
              <a
                href="/#events"
                class="block md:px-4 transition hover:text-primary"
              >
                <span>Events</span>
              </a>
            </li>
            <li>
              <a
                href="/#testimonials"
                class="block md:px-4 transition hover:text-primary"
              >
                <span>Testimonials</span>
              </a>
            </li>
            <li>
              <a
                href="/#blog"
                class="block md:px-4 transition hover:text-primary"
              >
                <span>Blog</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </Container>
  </nav>
</header>
